# --- Git & Metadata ---
.git
.github
.gitignore
LICENSE
README.md

# --- Python Environment ---
# Exclude local virtual environments and bytecode
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
build/
dist/
*.egg-info/

# --- Local Data & State ---
# We exclude these because we handle them via Docker Volumes in docker-compose.yml.
# This ensures the container starts clean or uses the mounted host data.
*.db
*.faiss
*.pkl
backend/chat_history.db
vector_data.pkl
vector_index.faiss

# --- Testing & Debugging ---
# These are for your local machine and CI/CD, not the production container.
tests/
.pytest_cache/
testing_block/
sample_output.log
*.log

# --- Assets & UI ---
# Exclude source images if they are not needed by the UI at runtime
# (Though your structure suggests you need these for Streamlit)
# frontend/ai.jpg
# frontend/genai.jpg

# --- OS & IDE Metadata ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Secrets ---
# NEVER include  .env file in the Docker image
.env